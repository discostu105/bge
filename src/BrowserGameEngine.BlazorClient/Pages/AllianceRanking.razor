@page "/allianceranking"
@page "/games/{GameId}/allianceranking"
@using BrowserGameEngine.Shared
@inject HttpClient Http
@implements IDisposable

<h1>Alliance Ranking</h1>

@if (model == null) {
    <p><em>Loading...</em></p>
} else if (!model.Any()) {
    <p>No alliances with 2 or more members yet.</p>
} else {
    <table class="table">
        <thead>
            <tr>
                <th>#</th>
                <th>Name</th>
                <th>Members</th>
                <th>Total Land</th>
                <th>Avg Land</th>
                <th>Score</th>
            </tr>
        </thead>
        <tbody>
            @for (int i = 0; i < model.Length; i++) {
                var item = model[i];
                <tr>
                    <td>@(i + 1)</td>
                    <td><a href="alliances/@item.AllianceId">@item.Name</a></td>
                    <td>@item.MemberCount</td>
                    <td>@item.TotalLand.ToString("N0")</td>
                    <td>@item.AvgLand.ToString("N0")</td>
                    <td>@item.Score.ToString("N1")</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    [Parameter]
    public string? GameId { get; set; }

    private AllianceRankingViewModel[]? model;
    private CancellationTokenSource? _cts;

    protected override async Task OnInitializedAsync() {
        await LoadData();
        _cts = new CancellationTokenSource();
        _ = RunRefreshLoop(_cts.Token);
    }

    private async Task RunRefreshLoop(CancellationToken ct) {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(10));
        while (await timer.WaitForNextTickAsync(ct).ConfigureAwait(false)) {
            await InvokeAsync(LoadData);
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task LoadData() {
        model = await Http.GetFromJsonAsync<AllianceRankingViewModel[]>("api/allianceranking");
    }

    public void Dispose() {
        _cts?.Cancel();
        _cts?.Dispose();
    }
}
