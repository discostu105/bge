@using BrowserGameEngine.Shared

@* Deliverable 2: In-game victory progress bar.
   Currently a skeleton — wiring of live threshold/leader data is blocked on backend.
   See BGE-513 for open questions. *@

@if (Show) {
	<div class="bge-victory-progress-panel">
		<div class="d-flex justify-content-between align-items-baseline mb-1">
			<span class="fw-semibold small">Economic Victory Progress</span>
			<span class="text-muted small">Target: @Threshold.ToString("N0")</span>
		</div>
		<div class="progress" style="height: 12px;">
			<div class="progress-bar bge-victory-progress-bar"
				 role="progressbar"
				 style="width: @ProgressPercent%"
				 aria-valuenow="@ProgressPercent"
				 aria-valuemin="0"
				 aria-valuemax="100">
			</div>
		</div>
		<div class="d-flex justify-content-between mt-1">
			<span class="text-muted small">You: @PlayerScore.ToString("N0")</span>
			@if (LeaderScore > PlayerScore) {
				<span class="text-muted small">Leader: @LeaderScore.ToString("N0")</span>
			}
		</div>
	</div>
}

@code {
	[Parameter] public bool Show { get; set; }
	[Parameter] public decimal PlayerScore { get; set; }
	[Parameter] public decimal LeaderScore { get; set; }
	[Parameter] public decimal Threshold { get; set; } = 500_000;

	private int ProgressPercent => Threshold > 0
		? (int)Math.Min(100, Math.Round(PlayerScore / Threshold * 100))
		: 0;
}
