@using BrowserGameEngine.Shared

@if (Show && Model != null) {
	<div class="modal fade show d-block" tabindex="-1" role="dialog" aria-modal="true" aria-labelledby="victoryBannerTitle">
		<div class="modal-dialog modal-lg modal-dialog-centered">
			<div class="modal-content bge-victory-modal">
				<div class="modal-header @GetHeaderClass()">
					<div class="d-flex align-items-center gap-2">
						<span class="fs-3">@GetVictoryEmoji()</span>
						<div>
							<h5 class="modal-title mb-0" id="victoryBannerTitle">@GetVictoryTitle()</h5>
							<span class="badge @GetBadgeClass() mt-1">@GetBadgeText()</span>
						</div>
					</div>
					<button type="button" class="btn-close" @onclick="OnDismiss" aria-label="Close"></button>
				</div>

				<div class="modal-body">
					@if (Model.Standings.Count >= 1) {
						var winner = Model.Standings[0];
						<div class="bge-victory-winner-card text-center mb-4">
							<div class="fs-1">🏆</div>
							<div class="fw-bold fs-4">@winner.PlayerName</div>
							<div class="text-muted">@winner.Score.ToString("N0") land</div>
						</div>
					}

					@if (Model.Standings.Count > 1) {
						<h6 class="text-muted mb-2">Final Standings</h6>
						<table class="table table-sm">
							<thead>
								<tr>
									<th>Rank</th>
									<th>Player</th>
									<th class="text-end">Score</th>
								</tr>
							</thead>
							<tbody>
								@foreach (var entry in Model.Standings) {
									var isMe = entry.PlayerId == Model.CurrentPlayerId;
									<tr class="@(isMe ? "table-primary fw-semibold" : entry.IsWinner ? "table-warning" : "")">
										<td>
											@if (entry.IsWinner) {
												<span>🏆 #@entry.Rank</span>
											} else {
												<span>#@entry.Rank</span>
											}
										</td>
										<td>
											@entry.PlayerName
											@if (isMe) { <span class="badge bg-primary ms-1">You</span> }
										</td>
										<td class="text-end">@entry.Score.ToString("N0")</td>
									</tr>
								}
							</tbody>
						</table>
					}
				</div>

				<div class="modal-footer">
					<a class="btn btn-primary" href="games/@Model.GameId/results">View Full Results</a>
					<button type="button" class="btn btn-secondary" @onclick="OnDismiss">Dismiss</button>
				</div>
			</div>
		</div>
	</div>
	<div class="modal-backdrop fade show"></div>
}

@code {
	[Parameter, EditorRequired] public GameResultsViewModel? Model { get; set; }
	[Parameter] public bool Show { get; set; }
	[Parameter] public EventCallback OnDismiss { get; set; }

	private string GetHeaderClass() => Model?.VictoryConditionType switch {
		"EconomicThreshold" => "bge-victory-header-economic",
		"TimeExpired" => "bge-victory-header-time",
		"AdminFinalized" => "bge-victory-header-admin",
		_ => "bg-secondary text-white"
	};

	private string GetBadgeClass() => Model?.VictoryConditionType switch {
		"EconomicThreshold" => "bg-warning text-dark",
		"TimeExpired" => "bg-secondary",
		"AdminFinalized" => "bg-danger",
		_ => "bg-secondary"
	};

	private string GetBadgeText() => Model?.VictoryConditionType switch {
		"EconomicThreshold" => "CONQUERED",
		"TimeExpired" => "TIME EXPIRED",
		"AdminFinalized" => "ADMIN ENDED",
		_ => "FINISHED"
	};

	private string GetVictoryEmoji() => Model?.VictoryConditionType switch {
		"EconomicThreshold" => "🏅",
		"TimeExpired" => "⏰",
		"AdminFinalized" => "🔚",
		_ => "🎮"
	};

	private string GetVictoryTitle() => Model?.VictoryConditionType switch {
		"EconomicThreshold" => "Economic Victory!",
		"TimeExpired" => "Game Over — Time's Up",
		"AdminFinalized" => "Game Ended by Admin",
		_ => "Game Over"
	};
}
