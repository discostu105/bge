@page "/chat"
@page "/games/{GameId}/chat"
@using BrowserGameEngine.Shared
@using BrowserGameEngine.BlazorClient.Code
@inject HttpClient Http
@implements IDisposable

<h1>Game Chat</h1>

<style>
	.chat-window {
		height: 400px;
		overflow-y: auto;
		border: 1px solid #dee2e6;
		border-radius: 0.375rem;
		padding: 0.75rem;
		background: #fff;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.chat-message {
		padding: 0.5rem 0.75rem;
		border-radius: 0.375rem;
		background: #f8f9fa;
		border-left: 3px solid #0d6efd;
	}

	.chat-message-header {
		display: flex;
		justify-content: space-between;
		font-size: 0.8rem;
		margin-bottom: 0.25rem;
	}

	.chat-message-author {
		font-weight: bold;
		color: #0d6efd;
	}

	.chat-message-time {
		color: #6c757d;
	}

	.chat-message-body {
		font-size: 0.9rem;
	}
</style>

@if (!string.IsNullOrEmpty(lastError)) {
	<div class="alert alert-danger">@lastError</div>
}

<div class="card mb-3">
	<div class="card-body">
		<div class="input-group">
			<input type="text" class="form-control" placeholder="Type a message..." maxlength="500"
				@bind="newMessageBody" @bind:event="oninput" @onkeydown="OnKeyDown" />
			<button class="btn btn-primary" @onclick="HandlePostMessage" disabled="@(string.IsNullOrWhiteSpace(newMessageBody))">
				Send
			</button>
		</div>
		<small class="text-muted">@newMessageBody.Length / 500</small>
	</div>
</div>

<div class="chat-window" @ref="chatWindowRef">
	@if (messages == null) {
		<p><em>Loading...</em></p>
	} else if (messages.Count == 0) {
		<p class="text-muted text-center mt-3">No messages yet. Start the conversation!</p>
	} else {
		@foreach (var msg in messages) {
			<div class="chat-message">
				<div class="chat-message-header">
					<span class="chat-message-author">@msg.AuthorName</span>
					<span class="chat-message-time">@msg.CreatedAt.ToString("HH:mm:ss")</span>
				</div>
				<div class="chat-message-body">@msg.Body</div>
			</div>
		}
	}
</div>

@code {
	[Parameter]
	public string? GameId { get; set; }

	private List<ChatMessageViewModel>? messages;
	private string newMessageBody = "";
	private string? lastMessageId;
	private string? lastError;
	private CancellationTokenSource? _cts;
	private ElementReference chatWindowRef;

	protected override async Task OnInitializedAsync() {
		await LoadMessages(initialLoad: true);
		_cts = new CancellationTokenSource();
		_ = RunRefreshLoop(_cts.Token);
	}

	private async Task RunRefreshLoop(CancellationToken ct) {
		using var timer = new PeriodicTimer(TimeSpan.FromSeconds(5));
		while (await timer.WaitForNextTickAsync(ct).ConfigureAwait(false)) {
			await InvokeAsync(() => LoadMessages(initialLoad: false));
			await InvokeAsync(StateHasChanged);
		}
	}

	private async Task LoadMessages(bool initialLoad) {
		try {
			string url = (lastMessageId != null && !initialLoad)
				? $"api/chat?after={lastMessageId}"
				: "api/chat";

			var result = await Http.GetFromJsonAsync<ChatMessagesViewModel>(url);
			if (result == null) return;

			if (initialLoad || lastMessageId == null) {
				messages = result.Messages;
			} else if (result.Messages.Count > 0) {
				messages ??= new List<ChatMessageViewModel>();
				messages.AddRange(result.Messages);
			}

			if (messages?.Count > 0) {
				lastMessageId = messages[^1].MessageId;
			}
		} catch {
			// Silently ignore polling errors
		}
	}

	private async Task HandlePostMessage() {
		if (string.IsNullOrWhiteSpace(newMessageBody)) return;
		lastError = null;
		var body = newMessageBody;
		newMessageBody = "";
		var response = await Http.PostAsJsonAsync("api/chat", new PostChatMessageRequest(body));
		if (response.IsSuccessStatusCode) {
			await LoadMessages(initialLoad: false);
			StateHasChanged();
		} else {
			lastError = await response.Content.ReadAsStringAsync();
		}
	}

	private async Task OnKeyDown(KeyboardEventArgs e) {
		if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(newMessageBody)) {
			await HandlePostMessage();
		}
	}

	public void Dispose() {
		_cts?.Cancel();
		_cts?.Dispose();
	}
}
