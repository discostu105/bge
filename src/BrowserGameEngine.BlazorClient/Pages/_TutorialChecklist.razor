@using BrowserGameEngine.BlazorClient.Code
@inject TutorialService Tutorial
@implements IDisposable

@if (Tutorial.IsLoaded)
{
	@if (!Tutorial.IsDismissed)
	{
		<div class="bge-tutorial-card">
			<div class="bge-tutorial-card-header">
				<span>&#128640; Getting Started</span>
				<button class="bge-tutorial-close" @onclick="Dismiss" title="Hide tutorial">&times;</button>
			</div>
			<div class="bge-tutorial-card-body">
				<div class="bge-tutorial-progress-bar">
					<div class="bge-tutorial-progress-fill" style="width: @ProgressPct%"></div>
				</div>
				<div class="bge-tutorial-progress-label">@Tutorial.CompletedCount / 5 complete</div>
				<ul class="bge-tutorial-steps">
					@for (int i = 0; i < _stepDefs.Length; i++)
					{
						var idx = i;
						var done = Tutorial.Steps[idx];
						<li class="bge-tutorial-step @(done ? "done" : "")">
							<span class="bge-tutorial-step-icon">@(done ? "✓" : "○")</span>
							<a href="@StepLink(idx)">
								@if (done)
								{
									<s>@_stepDefs[idx].Title</s>
								}
								else
								{
									@_stepDefs[idx].Title
								}
							</a>
						</li>
					}
				</ul>
				<button class="bge-tutorial-dismiss-btn" @onclick="Dismiss">
					Got it &mdash; hide tutorial
				</button>
			</div>
		</div>
	}
	else
	{
		<button class="bge-tutorial-fab" @onclick="Show" title="Open tutorial checklist">
			&#128203;
		</button>
	}
}

@code {
	[Parameter]
	public string? GameId { get; set; }

	private readonly (string Title, string Page)[] _stepDefs =
	[
		("Build your first unit", "base"),
		("Assign a worker to a resource", "base"),
		("Start a research upgrade", "upgrades"),
		("Attack an enemy player", "units"),
		("Join or create an alliance", "alliances"),
	];

	private int ProgressPct => Tutorial.CompletedCount * 20;

	private string StepLink(int idx)
	{
		var page = _stepDefs[idx].Page;
		return string.IsNullOrEmpty(GameId) ? page : $"games/{GameId}/{page}";
	}

	protected override async Task OnAfterRenderAsync(bool firstRender)
	{
		if (firstRender)
		{
			await Tutorial.LoadAsync();
			StateHasChanged();
		}
	}

	protected override void OnInitialized()
	{
		Tutorial.OnChanged += OnTutorialChanged;
	}

	private void OnTutorialChanged() => InvokeAsync(StateHasChanged);

	private async Task Dismiss()
	{
		await Tutorial.DismissAsync();
	}

	private async Task Show()
	{
		await Tutorial.ShowAsync();
	}

	public void Dispose()
	{
		Tutorial.OnChanged -= OnTutorialChanged;
	}
}
